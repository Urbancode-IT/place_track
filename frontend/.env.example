# Local dev (vite proxy still sends /api → localhost:5001 if you use relative /api)
VITE_API_URL=http://localhost:5001/api
VITE_SOCKET_URL=http://localhost:5001

# Production (see .env.production): point at Render backend, e.g.
# VITE_API_URL=https://your-service.onrender.com/api
# VITE_SOCKET_URL=https://your-service.onrender.com

# Firebase Web SDK config
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_web_push_certificate_key_pair
