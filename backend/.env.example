PORT=5001
NODE_ENV=development

# PostgreSQL connection (matches your pgAdmin)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin@123
DB_NAME=Placement_Tracking

JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Required for trainer / student emails. Gmail: enable 2FA → create an App Password → use it as SMTP_PASS (not your normal password).
# SMTP_FROM should match SMTP_USER for Gmail. After start, GET http://localhost:5001/health → mail.verified should be true.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=PlaceTrack <youraddress@gmail.com>

# Firebase Admin (pick ONE)
# Option A: absolute path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=C:/path/to/firebase-service-account.json
# Option B: JSON string (single line)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Local: Vite dev server. Production: your real site URL (no trailing slash).
FRONTEND_URL=http://localhost:5173
# Browsers send Origin — must list every frontend URL (comma-separated). Merged with FRONTEND_URL in code.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Production example (custom domain + Render API) — set BOTH on Render:
# FRONTEND_URL=https://placetrack.urbancode.in
# CORS_ORIGIN=https://placetrack.urbancode.in
# Add https://www.placetrack.urbancode.in too if you use www.

# Interview start = calendar day from interview.date + timeSlot text; default India IST
INTERVIEW_SCHEDULE_OFFSET=+05:30
INTERVIEW_SCHEDULE_TZ=Asia/Kolkata

# --- Google Chat (today + tomorrow board @ 10 PM India) ---
# 1) Chat space → Apps & integrations → Incoming webhooks → paste full URL here
GOOGLE_CHAT_WEBHOOK_URL=
# 2) Local test: npm run chat:ping   |   Full board: npm run chat:board
# 3) Render free tier: set GOOGLE_CHAT_DISABLE_INTERNAL_CRON=true, set GOOGLE_CHAT_CRON_SECRET to a long random string,
#    then on cron-job.org schedule GET daily 22:00 Asia/Kolkata:
#    https://YOUR-RENDER.onrender.com/api/public/cron/google-chat-board?secret=YOUR_SECRET
# 4) Same digest also emailed daily (10 PM India) — comma-separated. If empty, all ADMIN users with email get it.
DAILY_BOARD_EMAIL_TO=
# Interview create/update → immediate Google Chat: all (default) | today | off
GOOGLE_CHAT_IMMEDIATE_NOTIFY=all
GOOGLE_CHAT_CRON_TZ=Asia/Kolkata
GOOGLE_CHAT_DISABLE_INTERNAL_CRON=false
GOOGLE_CHAT_CRON_SECRET=
# How many minutes ± around “30 min before” the cron accepts (runs every minute)
TRAINER_REMINDER_WINDOW_MIN=5
# Set to false to turn off 30-minute trainer emails
TRAINER_REMINDER_ENABLED=true
